{
  "name": "water-ring-toss",
  "version": "1.0.0",
  "description": "80s Water Ring Toss (水壓套圈) — PixiJS v8 + Matter.js + Electron",
  "main": "dist-electron/main.js",
  "author": "Water Ring Toss",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "tsc -p tsconfig.electron.json && concurrently -k \"vite\" \"wait-on http://127.0.0.1:5173 && electron .\"",
    "build": "vite build && tsc -p tsconfig.electron.json",
    "build:web": "vite build",
    "preview": "vite preview",
    "electron": "tsc -p tsconfig.electron.json && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --x64 --arm64",
    "dist:win:x64": "npm run build && electron-builder --win --x64",
    "dist:win:arm64": "npm run build && electron-builder --win --arm64",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.electron.json --noEmit"
  },
  "dependencies": {
    "matter-js": "^0.20.0",
    "pixi.js": "^8.6.6"
  },
  "devDependencies": {
    "@types/matter-js": "^0.19.8",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.waterringtoss.app",
    "productName": "Water Ring Toss",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64", "arm64"]
        },
        {
          "target": "portable",
          "arch": ["x64", "arm64"]
        }
      ],
      "artifactName": "${productName}-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true
    },
    "linux": {
      "target": ["AppImage"],
      "category": "Game"
    }
  }
}
